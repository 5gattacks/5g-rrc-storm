+
+  UE->storm_timer_active = false;
+  rrc_gNB_storm_action(rrc, ue_context_p);
+}
+
+static void storm_advance_window(gNB_RRC_INST *rrc)
+{
+  rrc->storm_slot_idx = (rrc->storm_slot_idx + 1) % STORM_NUM_SLOTS;
+
+  rrc->storm_msg4_count -= rrc->storm_slots[rrc->storm_slot_idx].msg4;
+  rrc->storm_msg5_count -= rrc->storm_slots[rrc->storm_slot_idx].msg5;
+
+  rrc->storm_slots[rrc->storm_slot_idx].msg4 = 0;
+  rrc->storm_slots[rrc->storm_slot_idx].msg5 = 0;
+}
+
+static inline void storm_count_msg4(gNB_RRC_INST *rrc)
+{
+  rrc->storm_slots[rrc->storm_slot_idx].msg4++;
+  rrc->storm_msg4_count++;
+}
+
+static inline void storm_count_msg5(gNB_RRC_INST *rrc)
+{
+  rrc->storm_slots[rrc->storm_slot_idx].msg5++;
+  rrc->storm_msg5_count++;
+}
+
+static void evaluate_rrc_storm()
+{
+  gNB_RRC_INST *rrc = RC.nrrrc[0];  
+  storm_advance_window(rrc);
+
+  const uint32_t msg4 = rrc->storm_msg4_count;
+  const uint32_t msg5 = rrc->storm_msg5_count;
+  const uint32_t r2 = (msg4 == 0) ? 100 : (100 * msg5) / msg4;
+
+  LOG_D(NR_RRC, "[STORM STATS] Msg4=%u Msg5=%u R2=%u%% Active=%d\n", msg4, msg5, r2, rrc->storm_active);
+
+  if (!rrc->storm_active) {
+    if (msg4 >= STORM_MIN_MSG4 && r2 < STORM_R2_START_THRES) {
+      LOG_W(NR_RRC, "RRC storm detected: Msg4=%u Msg5=%u R2=%u%%\n", msg4, msg5, r2);
+      mitigate_rrc_storm(rrc);
+    }
+  } else {
+    if (r2 >= STORM_R2_STOP_THRES) {
+      LOG_W(NR_RRC, "RRC storm ended: Msg4=%u Msg5=%u R2=%u%%\n", msg4, msg5, r2);
+      rrc->storm_active = false;
+    }
+  }
+}
