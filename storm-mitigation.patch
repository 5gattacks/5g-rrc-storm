+int ta_to_bucket(int16_t ta) {
+  if (ta < 0) ta = 0;
+  int b = ta / NR_TA_BUCKET_WIDTH;
+  if (b >= NR_TA_NUM_BUCKETS) b = NR_TA_NUM_BUCKETS - 1;
+  return b;
+}
+
+void rrc_gNB_storm_action(gNB_RRC_INST *rrc, rrc_gNB_ue_context_t *ue_ctx)
+{
+  gNB_RRC_UE_t *UE = &ue_ctx->ue_context;
+  int b = ta_to_bucket(UE->ta);
+
+  LOG_UE_DL_EVENT(UE, "releasing UE %04x (rrc_ue_id=%u TA=%d bucket=%d)\n",
+                      UE->rnti, 
+                      UE->rrc_ue_id,
+                      UE->ta, 
+                      b);
+
+  f1_ue_data_t ue_data = cu_get_f1_ue_data(UE->rrc_ue_id);
+  RETURN_IF_INVALID_ASSOC_ID(ue_data.du_assoc_id);
+
+  f1ap_storm_ue_action_cmd_t storm_ue_action_cmd = {
+    .gNB_CU_ue_id = UE->rrc_ue_id,
+    .gNB_DU_ue_id = ue_data.secondary_ue
+  };
+
+  rrc->mac_rrc.storm_ue_action_command(ue_data.du_assoc_id, &storm_ue_action_cmd);
+  if(UE->storm_timer_active)
+    timer_remove(UE->storm_timer_id);
+  rrc_remove_ue(rrc, ue_ctx);
+  rrc->rrc_half_open_per_ta[b]--;
+  rrc->rrc_half_open_total--;
+}
+
+static void rrc_storm_handle_suspicious(gNB_RRC_INST *rrc)
+{
+  rrc_gNB_ue_context_t *ue_ctx, *tmp;
+  RB_FOREACH_SAFE(ue_ctx, rrc_nr_ue_tree_s, &rrc->rrc_ue_head, tmp) {
+    gNB_RRC_UE_t *UE = &ue_ctx->ue_context;
+
+    if (!UE->rrc_half_open || ta_to_bucket(UE->ta) != rrc->storm_suspicious_bucket_index)
+      continue;
+
+    rrc_gNB_storm_action(rrc, ue_ctx);
+  }
+}
+
+void mitigate_rrc_storm(gNB_RRC_INST *rrc)
+{
+  if(rrc->storm_active) return;
+
+  int total = rrc->rrc_half_open_total;
+  LOG_W(NR_RRC, "mitigate_rrc_storm triggered: %d half-open RRC connections\n", total);
+
+  if (total == 0) {
+    rrc->storm_active = false;
+    return;
+  }
+
+  rrc->storm_active = true;
+  int max_bucket = -1;
+  int max_count = 0; 
+
+  for (int b = 0; b < NR_TA_NUM_BUCKETS; b++) {
+    int count = rrc->rrc_half_open_per_ta[b];
+
+    if (count > max_count) {
+      max_count = count;
+      max_bucket = b;
+    }    
+  }
+  
+  if (max_bucket != -1) {
+    rrc->storm_suspicious_bucket_index = max_bucket;
+    
+    LOG_W(NR_RRC,
+          "TA bucket %d (TA [%d..%d]) selected as suspicious: %d of %d half-opens.\n",
+          max_bucket, max_bucket * NR_TA_BUCKET_WIDTH, (max_bucket + 1) * NR_TA_BUCKET_WIDTH - 1, max_count, total);
+    
+    rrc_storm_handle_suspicious(rrc);
+  }
+}
+
+void rrc_handle_storm_timeout(rrc_storm_ue_timeout_t *t)
+{
+  gNB_RRC_INST *rrc = RC.nrrrc[0];  
+  rrc_gNB_ue_context_t *ue_context_p = rrc_gNB_get_ue_context(rrc, t->rrc_ue_id);
+
+  if (!ue_context_p)
+    return;
+    
+  gNB_RRC_UE_t *UE = &(ue_context_p->ue_context);
+
+  if (!UE->rrc_half_open)
+    return;
+
