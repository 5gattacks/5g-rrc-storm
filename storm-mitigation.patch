+  UE = UE ? UE : find_ra_UE(&mac->UE_info, cmd->gNB_DU_ue_id);
+
+  if (UE == NULL) {
+    NR_SCHED_UNLOCK(&mac->sched_lock);
+    return;
+  }
+
+  LOG_W(MAC, "Storm action command: Removing UE %d\n", cmd->gNB_DU_ue_id);
+
+  instance_t f1inst = get_f1_gtp_instance();
